# ── Server ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── PostgreSQL ─────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://seatlock:seatlock_password@localhost:5432/seatlock

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Business rules ─────────────────────────────────────
SEAT_HOLD_DURATION_SECONDS=300

# ── Mock payment gateway ───────────────────────────────
MOCK_PAYMENT_FAILURE_RATE=0.05

# ── Email (optional — leave blank to log emails to console instead) ──
# Free option: create a free Mailtrap.io sandbox inbox for testing
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@seatlock.app
